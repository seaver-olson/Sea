#include <stdio.h>

namespace calculator {
  float add(float a, float b){
      return a+b;
    }

  typedef struct {
    float x, y;
  } Vector2D;

  typedef struct {
    float x, y, z;
  } Vector3D;

  int accumulate(int* arr, size_t size) {
    int sum = 0;
    for (size_t i = 0; i < size; i++) {
      sum += arr[i];
    }
    return sum;
  }
};

int main(){
  printf("%d\n:", calculator::add(6,7));
  return 0;
}
